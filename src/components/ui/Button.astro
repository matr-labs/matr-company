---
import { cn } from "@lib/cn";

interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  external?: boolean;
  disabled?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  external = false,
  disabled = false,
  class: className,
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-md font-sans font-medium " +
  "transition-colors duration-150 disabled:cursor-not-allowed disabled:opacity-50 " +
  "focus-visible:outline-none";

const variants = {
  primary: "bg-accent text-surface hover:opacity-90",
  secondary: "bg-surface text-text border border-border hover:bg-bg",
  ghost: "bg-transparent text-text hover:bg-surface",
};

const sizes = {
  sm: "text-sm px-3 py-1.5",
  md: "text-base px-5 py-2.5",
  lg: "text-md px-7 py-3",
};

const classes = cn(base, variants[variant], sizes[size], className);
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

{
  href ? (
    <a href={href} class={classes} rel={rel} target={target} aria-disabled={disabled}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} disabled={disabled}>
      <slot />
    </button>
  )
}
