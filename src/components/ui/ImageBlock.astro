---
import { Image } from "astro:assets";
import { cn } from "@lib/cn";

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  format?: "webp" | "avif" | "png" | "jpg";
  sizes?: string;
  rounded?: boolean;
  
  fallback?: string;
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = "lazy",
  format = "webp",
  sizes,
  rounded = false,
  fallback = "/images/placeholder.svg",
  class: className,
} = Astro.props;

const classes = cn("h-auto w-full object-cover", rounded && "rounded-lg", className);
const decoding = loading === "eager" ? "sync" : "async";

const TRANSPARENT_PIXEL =
  "data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==";
const onError = `this.onerror=null;this.src='${TRANSPARENT_PIXEL}';this.classList.add('is-placeholder');`;
---

{
  typeof src === "string" ? (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      sizes={sizes}
      class={classes}
      style={`--img-fallback:url('${fallback}')`}
      onerror={onError}
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      format={format}
      sizes={sizes}
      class={classes}
    />
  )
}

<style>
  
  .is-placeholder {
    background-color: #e7e5e4;
    background-image: var(--img-fallback);
    background-repeat: no-repeat;
    background-position: center;
    background-size: clamp(1.5rem, 28%, 4rem);
    
    min-width: 3rem;
    min-height: 3rem;
  }
</style>
