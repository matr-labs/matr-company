---
import Heading from "@ui/Heading.astro";

interface Props {
  heading: string;
}

const { heading } = Astro.props;
---

<div>
  <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted" class="font-mono uppercase">
    {heading}
  </Heading>
  <div class="mt-6">
    <slot />
  </div>
</div>
