---
// Global smooth scrolling via Lenis, synced to GSAP ScrollTrigger.
// Driven by <html data-smooth-scroll="true"> (config.motion.smoothScroll) and
// skipped for users who prefer reduced motion. Lenis smooths the real scroll
// position, so wheel jumps become an eased glide — pinned ScrollTriggers ride
// on top of it instead of snapping to discrete scroll deltas.
---

<script>
  import Lenis from "lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let lenis: Lenis | undefined;

  // gsap.ticker reports time in seconds; Lenis' raf wants milliseconds. Driving
  // Lenis from the ticker keeps the scroll and the animations on one rAF loop.
  const tick = (time: number) => lenis?.raf(time * 1000);

  // When ScrollTrigger recomputes (e.g. after a pin adds its spacer and the
  // document grows), re-measure Lenis. Without this, Lenis keeps the old scroll
  // limit and you can't reach content past the pin — that's the missing footer.
  const lenisResize = () => lenis?.resize();

  function start() {
    if (lenis) return;

    const enabled = document.documentElement.dataset.smoothScroll === "true";
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!enabled || reduce) return;

    lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    lenis.on("scroll", ScrollTrigger.update);
    ScrollTrigger.addEventListener("refresh", lenisResize);

    gsap.ticker.add(tick);
    gsap.ticker.lagSmoothing(0);
  }

  function stop() {
    if (!lenis) return;
    gsap.ticker.remove(tick);
    ScrollTrigger.removeEventListener("refresh", lenisResize);
    lenis.destroy();
    lenis = undefined;
  }

  // A scroll-locked flag lives on <html data-scroll-locked>; honouring it here
  // means a lock requested before Lenis exists still applies once it starts.
  function applyLock() {
    if (!lenis) return;
    if (document.documentElement.dataset.scrollLocked === "true") lenis.stop();
    else lenis.start();
  }
  window.addEventListener("matr:scroll-lock", applyLock);
  window.addEventListener("matr:scroll-unlock", applyLock);

  // Scroll to top through Lenis when it's driving, else native.
  function scrollToTop() {
    if (lenis) lenis.scrollTo(0, { duration: 1.2 });
    else window.scrollTo({ top: 0, behavior: "smooth" });
  }
  window.addEventListener("matr:scroll-top", scrollToTop);

  // A link marked [data-samepage] that points at the current page scrolls to
  // the top instead of navigating.
  const normalizePath = (p: string) =>
    p !== "/" && p.endsWith("/") ? p.slice(0, -1) : p;
  document.addEventListener(
    "click",
    (event) => {
      if (
        event.defaultPrevented ||
        event.button !== 0 ||
        event.metaKey ||
        event.ctrlKey ||
        event.shiftKey ||
        event.altKey
      )
        return;
      const link = (event.target as Element).closest<HTMLAnchorElement>(
        "a[data-samepage]",
      );
      if (!link) return;
      if (
        normalizePath(new URL(link.href).pathname) ===
        normalizePath(window.location.pathname)
      ) {
        event.preventDefault();
        scrollToTop();
      }
    },
    true,
  );

  // Initial load + every Astro view-transition navigation.
  document.addEventListener("astro:page-load", () => {
    start();
    applyLock();
    ScrollTrigger.refresh();
  });
  // Tear down before the DOM is swapped so we re-init cleanly on the next page.
  document.addEventListener("astro:before-swap", stop);
  // A fresh navigation should land at the top (Lenis otherwise keeps the old
  // scroll position across the swap).
  document.addEventListener("astro:after-swap", () => window.scrollTo(0, 0));
</script>
