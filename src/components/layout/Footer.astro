---
import Container from "@ui/Container.astro";
import Heading from "@ui/Heading.astro";
import ArrowLink from "@ui/ArrowLink.astro";
import FooterColumn from "@layout/FooterColumn.astro";
import { footerNav } from "@data/nav";
import { site } from "@content/site";
import footer from "@data/footer.json";

const year = new Date().getFullYear();
const { city, region, postalCode } = site.address;
---

<footer class="bg-surface text-text border-t">
  <Container width="full" class="py-16">
    <div class="grid grid-cols-2 gap-x-8 gap-y-12 md:grid-cols-4">
      <FooterColumn heading={footer.headings.connect}>
        <ul class="flex flex-col gap-1">
          {
            footer.social.map((link) => (
              <li>
                <ArrowLink
                  href={link.href}
                  label={link.label}
                  external
                  size="sm"
                  sizeMd="lg"
                  class="-ml-3"
                />
              </li>
            ))
          }
        </ul>
      </FooterColumn>

      <FooterColumn heading={footer.headings.sayHello}>
        <div class="space-y-2">
          <ArrowLink
            href={`mailto:${site.email}`}
            label={site.email}
            arrow
            size="sm"
            sizeMd="lg"
            class="-ml-3"
          />
          <Heading level={4} size="sm" sizeMd="lg" weight="medium">
            {city}, {region}
          </Heading>
        </div>
      </FooterColumn>

      <FooterColumn heading={footer.headings.localTime}>
        <div class="space-y-2" data-localtime data-tz={footer.localTime.timeZone}>
          <Heading level={4} size="sm" sizeMd="lg" weight="medium">
            <span data-date>—</span>
          </Heading>
          <Heading level={4} size="sm" sizeMd="lg" weight="medium">
            <span data-time>—</span>
          </Heading>
        </div>
      </FooterColumn>

      <FooterColumn heading={footer.headings.index}>
        <ul class="flex flex-col gap-2">
          {
            footerNav.map((item) => (
              <li>
                <ArrowLink
                  href={item.href}
                  label={item.label}
                  samepage
                  arrow={false}
                  size="sm"
                  sizeMd="lg"
                  class="-ml-3"
                />
              </li>
            ))
          }
        </ul>
      </FooterColumn>
    </div>

    <hr class="my-12 border-0 border-t border-border" />

    <div class="flex items-end gap-4 sm:gap-6">
      <div class="aspect-square w-[clamp(2rem,4vw,4.25rem)] shrink-0 bg-text"></div>
      <Heading level={2} size="2xl" weight="bold" tracking="tight" leading="none">
        {site.name}.
      </Heading>
    </div>

    <div
      class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between"
    >
      <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted" class="font-mono">
        ©{" "}{year}{" "}{site.name.toUpperCase()}. {footer.legal.rights.toUpperCase()}.
      </Heading>
      <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted" class="font-mono">
        MADE IN {footer.legal.madeIn.toUpperCase()}
      </Heading>
    </div>
  </Container>
</footer>

<script>
  function tick() {
    const now = new Date();
    document.querySelectorAll<HTMLElement>("[data-localtime]").forEach((el) => {
      const tz = el.dataset.tz || undefined;
      const dateEl = el.querySelector("[data-date]");
      const timeEl = el.querySelector("[data-time]");
      if (dateEl) {
        dateEl.textContent = now.toLocaleDateString("en-US", {
          timeZone: tz,
          month: "short",
          day: "numeric",
          year: "numeric",
        });
      }
      if (timeEl) {
        const time = now.toLocaleTimeString("en-US", {
          timeZone: tz,
          hour12: true,
          hour: "numeric",
          minute: "2-digit",
          second: "2-digit",
        });
        const tzName =
          new Intl.DateTimeFormat("en-US", { timeZone: tz, timeZoneName: "short" })
            .formatToParts(now)
            .find((part) => part.type === "timeZoneName")?.value ?? "";
        timeEl.textContent = `${time} (${tzName})`;
      }
    });
  }

  tick();
  setInterval(tick, 1000);
  document.addEventListener("astro:page-load", tick);
</script>
