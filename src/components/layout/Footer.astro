---
import Container from "@ui/Container.astro";
import Text from "@ui/Text.astro";
import { footerNav } from "@data/nav";
import { site } from "@content/site";

const year = new Date().getFullYear();
const socials = Object.entries(site.social);
---

<footer class="border-t border-border bg-surface">
  <Container width="full" class="flex flex-col gap-8 py-12 sm:flex-row sm:items-start sm:justify-between">
    <div class="max-w-sm">
      <p class="font-sans text-md font-semibold tracking-tight">{site.name}</p>
      <Text tone="muted" size="sm" class="mt-2">{site.tagline}</Text>
    </div>

    <nav aria-label="Footer">
      <ul class="flex flex-col gap-2 sm:items-end">
        {
          footerNav.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-muted transition-colors hover:text-accent">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </Container>

  <Container width="full" class="flex flex-col gap-4 border-t border-border py-6 sm:flex-row sm:items-center sm:justify-between">
    <Text tone="muted" size="xs">© {year}{" "}{site.name}. All rights reserved.</Text>
    <ul class="flex gap-4">
      {
        socials.map(([name, href]) => (
          <li>
            <a
              href={href}
              rel="noopener noreferrer"
              target="_blank"
              class="text-xs capitalize text-muted transition-colors hover:text-accent"
            >
              {name}
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</footer>
