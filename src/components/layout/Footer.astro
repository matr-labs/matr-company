---
import Container from "@ui/Container.astro";
import Heading from "@ui/Heading.astro";
import { footerNav } from "@data/nav";
import { site } from "@content/site";

const year = new Date().getFullYear();

const socialLabels: Record<string, string> = {
  twitter: "X / Twitter",
  instagram: "Instagram",
  linkedin: "LinkedIn",
};
const socials = Object.entries(site.social);
const { city, region, postalCode } = site.address;
---

<footer class="bg-surface text-text">
  <Container width="full" class="py-16">
    <div class="grid grid-cols-2 gap-x-8 gap-y-12 md:grid-cols-4 ">
      <div>
        <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted">
          CONNECT
        </Heading>
        <ul class="mt-6 space-y-1">
          {
            socials.map(([key, href]) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener"
                  class="transition-colors hover:text-accent"
                >
                  <Heading level={4} size="lg" weight="medium" class="max-md:text-sm">
                    {socialLabels[key] ?? key}
                  </Heading>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted">
          SAY HELLO
        </Heading>
        <div class="mt-6 space-y-1">
          <a
            href={`mailto:${site.email}`}
            class="block transition-colors hover:text-accent"
          >
            <Heading level={4} size="lg" weight="medium" class="max-md:text-sm">{site.email}</Heading>
          </a>
          <Heading level={4} size="lg" weight="medium" class="max-md:text-sm">
            {city}, {region} {postalCode}
          </Heading>
        </div>
      </div>

      <div>
        <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted">
          LOCAL TIME
        </Heading>
        <div class="mt-6  space-y-1">
          <Heading level={4} size="lg" weight="medium" class="max-md:text-sm">
            24 Jan 2026

          </Heading>

                    <Heading level={4} size="lg" weight="medium" class="max-md:text-sm">
            <span data-clock>--:--:-- </span> PM (EST)
          </Heading>
         
        </div>
      </div>

      <div>
        <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted">
          INDEX
        </Heading>
        <ul class="mt-6 space-y-1">
          {
            footerNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  data-samepage
                  class="transition-colors hover:text-accent"
                >
                  <Heading level={4} size="lg" weight="medium"  class="max-md:text-sm">
                    {item.label}
                  </Heading>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <hr class="my-12 border-0 border-t border-border" />

    <div class="flex items-end gap-4 sm:gap-6">
      <div
        class="aspect-square w-[clamp(2rem,4vw,4.25rem)] shrink-0 bg-text"
      ></div>
      <Heading level={2} size="2xl" weight="bold" tracking="tight" leading="none">
        {site.name}.
      </Heading>
    </div>

    <div
      class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between"
    >
      <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted">
        © {year}{" "}{site.name}. ALL RIGHTS RESERVED.
      </Heading>

      <Heading level={3} size="xs" weight="medium" tracking="wide" tone="muted">
        MADE IN {city.toUpperCase()}
      </Heading>
    </div>
  </Container>
</footer>

<script>
  function tick() {
    const el = document.querySelector("[data-clock]");
    if (!el) return;
    el.textContent = new Date().toLocaleTimeString("en-US", {
      hour12: false,
      timeZone: "America/Los_Angeles",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    });
  }

  tick();
  setInterval(tick, 1000);
  document.addEventListener("astro:page-load", tick);
</script>
