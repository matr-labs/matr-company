---
import Container from "@ui/Container.astro";
import { mainNav } from "@data/nav";
import { site } from "@content/site";
import { cn } from "@lib/cn";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="fixed w-full top-0 border-b border-border bg-surface z-50 ">
  <Container width="full" class="font-sans text-md font-semibold tracking-tight flex h-8 items-center justify-between gap-6">
    <a href="/" data-samepage class="">
      {site.name}
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-6">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                data-samepage
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cn(
                  "transition-colors hover:text-accent",
                  isActive(item.href) ? "text-text" : "text-muted",
                )}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a href="/contact" data-samepage class="text-muted hover:text-accent">
      Contact us
    </a>
  </Container>
</header>
