---
import Container from "@ui/Container.astro";
import { mainNav } from "@data/nav";
import { site } from "@content/site";
import { cn } from "@lib/cn";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-border bg-bg backdrop-blur">
  <Container width="full" class="flex h-8 items-center justify-between gap-6">
    <a href="/" class="font-sans text-md font-semibold tracking-tight">
      {site.name}
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-6">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cn(
                  "text-sm transition-colors hover:text-accent",
                  isActive(item.href) ? "text-text" : "text-muted",
                )}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </Container>
</header>
