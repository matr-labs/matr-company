---

import Section from "@ui/Section.astro";
import Container from "@ui/Container.astro";
import ImageBlock from "@ui/ImageBlock.astro";
import Heading from "@ui/Heading.astro";
import Text from "@ui/Text.astro";

import { home, servicesWithNo } from "@content/home";
const { services } = home;
---


<Section id="services" tone="surface" width="full" contained={false}>
  
  <div class="svcs">

    {
      servicesWithNo.map((service) => (
        // Each panel is the sticky header's containing block, so the header
        // releases (scrolls up + out) once you scroll past its media.
        <article class="svc-panel">
          <header class="svc-head">
            <Container width="default" class="w-full">
              <div class="svc-head__grid ">
                  <Heading level={4}>
                  ({service.no})
              </Heading>

                <div class="svc-head__main">
                  <Heading level={1} size="2xl">
                    {service.title}
                  </Heading>

                  <Heading
                    level={2}
                    class="ml-auto max-w-[38ch] max-md:max-w-none "
                  >
                    {service.description}
                  </Heading>
                </div>
              </div>
            </Container>
          </header>

          <div class="svc-media">
            <ImageBlock
              src={service.image}
              alt={service.title}
              sizes="100vw"
              class="svc-media__img h-full"
            />
          </div>
        </article>
      ))
    }
  </div>
</Section>

<style>
  .svcs {

    --stack-top: 2rem;
    --head-h: 7.5rem;
    position: relative;

  }

  .svcs__intro {
    padding: 0 var(--space-container) 2rem;
  }

  
  .svc-panel {
    position: relative;
  }

  
  .svc-head {
    position: sticky;
    top: var(--stack-top);
    z-index: 2;
    display: flex;
    align-items: top;
    width: 100%;
    min-height: var(--head-h);
    padding-block: 1.5rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .svc-head__grid {
    display: grid;
    grid-template-columns: 20% 1fr;
    align-items: start;
    width: 100%;
  }

  .svc-head__main {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 3vw, 3rem);
    min-width: 0;
  }

  
  .svc-media {
    position: relative;
    z-index: 0;
    width: 100%;
    height: calc(50vh - var(--stack-top) - var(--head-h));
    /* Clip the cover image so a tall source can't spill past the panel
       (the last panel's overflow was landing on the footer). */
    overflow: hidden;
  }
  .svc-media__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  
  @media (max-width: 768px) {
    .svc-head {
      position: static;
      align-items: stretch;
      height: auto;
      overflow: visible;
      padding-top: 1.25rem;
      padding-bottom: 1.25rem;
    }
    .svc-head__grid {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .svc-head__main {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-head {
      position: static;
    }
  }
</style>
