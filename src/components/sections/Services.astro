---

import Section from "@ui/Section.astro";
import ImageBlock from "@ui/ImageBlock.astro";
import Heading from "@ui/Heading.astro";
import Text from "@ui/Text.astro";

import { home, servicesWithNo } from "@content/home";
const { services } = home;
---


<Section id="services" tone="surface" width="full" contained={false}>
  
  <div class="svcs">
    <div class="svcs__intro">
      <Heading level={2} size="lg">{services.title}</Heading>
    </div>

    {
      servicesWithNo.map((service) => (
        // Each panel is the sticky header's containing block, so the header
        // releases (scrolls up + out) once you scroll past its media.
        <article class="svc-panel">
          <header class="svc-head">
            <Text tag="span" size="sm" tone="muted" class="flex-none font-mono">
              {service.no}
            </Text>

            <Heading level={1} size="2xl">
              {service.title}
            </Heading>

            <Heading
              level={2}
              class="ml-auto max-w-[38ch] max-md:max-w-none max-md:text-sm"
            >
              {service.description}
            </Heading>
          </header>

          <div class="svc-media">
            <ImageBlock
              src={service.image}
              alt={service.title}
              sizes="100vw"
              class="svc-media__img"
            />
          </div>
        </article>
      ))
    }
  </div>
</Section>

<style>
  .svcs {

    --stack-top: 2rem;
    --head-h: 7.5rem;
    position: relative;

  }

  .svcs__intro {
    padding: 0 var(--space-container) 2rem;
  }

  
  .svc-panel {
    position: relative;
  }

  
  .svc-head {
    position: sticky;
    top: var(--stack-top);
    z-index: 2; 
    display: flex;
    align-items: top;
    gap: clamp(1rem, 3vw, 3rem);
    width: 100%;
    height: var(--head-h);
    overflow: hidden;
    padding: 0 var(--space-container);
    background: var(--color-surface); 
    border-top: 1px solid var(--color-border);
  }

  
  .svc-media {
    position: relative;
    z-index: 0;
    width: 100%;
  }
  .svc-media__img {
    display: block;
    width: 100%;
    height: clamp(60vh, 78vh, 90vh);
    object-fit: cover;
  }

  
  @media (max-width: 768px) {
    .svc-head {
      position: static;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      height: auto;
      overflow: visible;
      padding: 1.25rem var(--space-container);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-head {
      position: static;
    }
  }
</style>
