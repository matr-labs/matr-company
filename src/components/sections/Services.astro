---
// Services — full-width panels with big typography. Each service header is
// sticky and stacks into a staircase as you scroll; the big placeholder images
// scroll behind the pinned headers, and the whole stack releases once you've
// scrolled past the section (pure-CSS sticky, bounded by the section).
// Typography comes entirely from the Heading/Text design-system components.
import ImageBlock from "@ui/ImageBlock.astro";
import Heading from "@ui/Heading.astro";
import Text from "@ui/Text.astro";
import { servicesWithNo, servicesIntro } from "@content/services";
import placeholder from "@assets/images/test-large.jpg";
---

<section class="svcs" aria-label={servicesIntro.label}>
  <div class="svcs__intro">
    <Heading level={2} size="lg">{servicesIntro.title}</Heading>
  </div>

  {
    servicesWithNo.map((service, i) => (
      <Fragment>
        <header class="svc-head" style={`--i:${i}`}>
          <Text tag="span" size="sm" tone="muted" class="flex-none font-mono">
            {service.no}
          </Text>

          <Heading
            level={1}
            size="2xl"
          >
            {service.title}
          </Heading>


   <Heading
           level={2}  class="ml-auto max-w-[38ch] max-md:max-w-none max-md:text-sm"
          >

            {service.description}
          </Heading>
        </header>

        <div class="svc-media" style={`--i:${i}`}>
          <ImageBlock
            src={placeholder}
            alt={`${service.title} — placeholder`}
            sizes="100vw"
            class="svc-media__img"
          />
        </div>
      </Fragment>
    ))
  }
</section>

<style>
  .svcs {
    /* pin point sits flush under the fixed 2rem nav; step = pinned header height */
    --stack-top: 2rem;
    --stack-step: 7.5rem;
    position: relative;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .svcs__intro {
    padding: var(--space-section) var(--space-container) 2rem;
  }

  /* ── Stacking headers (layout only — type is from Heading/Text) ──────────── */
  .svc-head {
    position: sticky;
    top: calc(var(--stack-top) + var(--i) * var(--stack-step));
    z-index: calc(1 + var(--i));
    display: flex;
    align-items: top;
    gap: clamp(1rem, 3vw, 3rem);
    width: 100%;
    height: var(--stack-step); /* fixed → clean, non-overlapping staircase */
    overflow: hidden;
    padding: 0 var(--space-container);
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  /* ── Big media, scrolls behind the pinned headers ───────────────────────── */
  .svc-media {
    position: relative;
    z-index: 0;
    width: 100%;
  }
  .svc-media__img {
    display: block;
    width: 100%;
    height: clamp(60vh, 78vh, 90vh);
    object-fit: cover;
  }

  /* Mobile: drop the stacking — headers flow normally, description below. */
  @media (max-width: 768px) {
    .svc-head {
      position: static;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      height: auto;
      overflow: visible;
      padding: 1.25rem var(--space-container);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-head {
      position: static;
    }
  }
</style>
