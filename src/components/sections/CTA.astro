---
import Container from "@ui/Container.astro";
import Heading from "@ui/Heading.astro";
import ArrowLink from "@ui/ArrowLink.astro";

interface Props {
  title: string;
  body?: string;
  action: { label: string; href: string };
  invert?: boolean;
}

const { title, body, action, invert = false } = Astro.props;
---

<section
  class:list={["cta relative overflow-hidden py-section", { "cta--invert": invert }]}
  data-cta
>
  <canvas
    data-cta-dither
    class="pointer-events-none absolute inset-0 h-full w-full [image-rendering:pixelated]"></canvas>
  <span class="cta__border cta__border--top"></span>
  <span class="cta__border cta__border--bottom"></span>

  <Container width="full">
    <div
      class="cta__content flex flex-col gap-8 md:flex-row md:items-center md:justify-between"
    >
      <div
        class="flex flex-col gap-4 md:flex-1 md:flex-row md:items-center md:gap-8"
      >
        <Heading level={2} size="xl">{title}</Heading>
        {
          body && (
            <Heading level={3} size="md" class="max-w-xl opacity-90">
              {body}
            </Heading>
          )
        }
      </div>
      <ArrowLink
        href={action.href}
        label={action.label}
        fill="surface"
        class="-ml-3 border-2 border-surface"
      />
    </div>
  </Container>
</section>

<style>
  .cta {
    --cta-ink: var(--color-text);
    --cta-paper: var(--color-surface);
    background-color: var(--cta-paper);
  }
  .cta--invert {
    --cta-ink: var(--color-surface);
    --cta-paper: var(--color-text);
  }

  [data-cta-dither] {
    color: var(--cta-ink);
  }

  .cta__content {
    position: relative;
    z-index: 2;
    color: var(--cta-ink);
    transition: color 0.5s ease;
  }
  .cta.is-filled .cta__content {
    color: var(--cta-paper);
  }

  .cta__border {
    position: absolute;
    left: 0;
    z-index: 1;
    width: 100%;
    height: 2px;
    background-color: var(--cta-ink);
    transform: scaleX(0);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta__border--top {
    top: 0;
    transform-origin: left;
  }
  .cta__border--bottom {
    bottom: 0;
    transform-origin: right;
  }
  .cta.is-drawn .cta__border {
    transform: scaleX(1);
  }
</style>

<script>
  import { DitherFill } from "@lib/dither";

  function parseRgb(value: string): [number, number, number] {
    const m = value.match(/\d+(?:\.\d+)?/g);
    return m && m.length >= 3 ? [+m[0], +m[1], +m[2]] : [0, 0, 0];
  }

  function setup() {
    document.querySelectorAll<HTMLElement>("[data-cta]").forEach((section) => {
      if (section.dataset.ready === "1") return;
      section.dataset.ready = "1";

      const canvas = section.querySelector<HTMLCanvasElement>("[data-cta-dither]");
      if (!canvas) return;

      const ink = parseRgb(getComputedStyle(canvas).color);
      const fill = new DitherFill(canvas, { px: 1, soft: 0.6, color: ink });
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            io.disconnect();
            section.classList.add("is-drawn");
            if (reduce) return;
            window.setTimeout(() => {
              fill.animateTo(1, 900);
              section.classList.add("is-filled");
            }, 700);
          });
        },
        { threshold: 0.35 },
      );
      io.observe(section);
    });
  }

  setup();
  document.addEventListener("astro:page-load", setup);
</script>
