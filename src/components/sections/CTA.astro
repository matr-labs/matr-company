---
import Section from "@ui/Section.astro";
import Heading from "@ui/Heading.astro";
import Text from "@ui/Text.astro";
import Button from "@ui/Button.astro";

interface Props {
  title: string;
  body?: string;
  action: { label: string; href: string };
}

const { title, body, action } = Astro.props;
---

<Section tone="accent" width="full">
  <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-col gap-4 md:flex-1 md:flex-row md:items-center md:gap-8">
      <Heading level={2} size="xl">{title}</Heading>
      {
        body && (
          <Heading level={3} size="md" class="max-w-xl opacity-90">
            {body}
          </Heading>
        )
      }
    </div>
    <Button
      href={action.href}
      variant="secondary"
      size="lg"
      class="w-full md:w-auto"
    >
      {action.label}
    </Button>
  </div>
</Section>
