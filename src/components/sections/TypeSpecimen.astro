---
import Section from "@ui/Section.astro";
import Heading from "@ui/Heading.astro";
import Text from "@ui/Text.astro";

const headingSizes = ["hero", "xl", "lg", "md", "base", "sm"] as const;
const levels = [1, 2, 3, 4, 5, 6] as const;
const textSizes = ["lg", "md", "base", "sm", "xs"] as const;
const weights = ["normal", "medium", "semibold", "bold"] as const;
const leadings = ["tight", "snug", "normal", "relaxed"] as const;
const trackings = ["tighter", "tight", "normal", "wide"] as const;

const colors = [
  { name: "bg", token: "--color-bg", box: "bg-bg" },
  { name: "surface", token: "--color-surface", box: "bg-surface" },
  { name: "text", token: "--color-text", box: "bg-text" },
  { name: "muted", token: "--color-muted", box: "bg-muted" },
  { name: "border", token: "--color-border", box: "bg-border" },
  { name: "accent", token: "--color-accent", box: "bg-accent" },
];

const specimen = "The quick brown fox jumps over the lazy dog";
const paragraph =
  "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.";

const groupClass = "border-t border-border pt-8";
const labelClass = "mb-4 font-mono text-xs uppercase tracking-wide text-muted";
const rowLabel = "w-28 shrink-0 font-mono text-xs text-muted";
---

<Section width="full" class="space-y-16">
  <div>
    <Text size="sm" tone="muted" class="font-mono uppercase tracking-wide">Type specimen</Text>
    <Heading level={1} size="xl" class="mt-2">Typography &amp; color</Heading>
    <Text tone="muted" measure class="mt-3">
      Live preview of every token. Tweak the values in <code>src/styles/tokens.css</code> and this page updates on save.
    </Text>
  </div>

  <div class={groupClass}>
    <p class={labelClass}>Size scale (font-size token)</p>
    <div class="space-y-4">
      {
        headingSizes.map((s) => (
          <div class="flex items-baseline gap-4">
            <span class={rowLabel}>--text-{s}</span>
            <Heading level={2} size={s} class="min-w-0">
              {specimen}
            </Heading>
          </div>
        ))
      }
    </div>
  </div>

  <div class={groupClass}>
    <p class={labelClass}>Heading levels (default size per level)</p>
    <div class="space-y-3">
      {
        levels.map((l) => (
          <div class="flex items-baseline gap-4">
            <span class={rowLabel}>H{l}</span>
            <Heading level={l}>{specimen}</Heading>
          </div>
        ))
      }
    </div>
  </div>

  <div class={groupClass}>
    <p class={labelClass}>Body text sizes</p>
    <div class="space-y-3">
      {
        textSizes.map((s) => (
          <div class="flex items-baseline gap-4">
            <span class={rowLabel}>--text-{s}</span>
            <Text size={s}>{specimen}</Text>
          </div>
        ))
      }
    </div>
  </div>

  <div class={groupClass}>
    <p class={labelClass}>Font weight</p>
    <div class="space-y-3">
      {
        weights.map((w) => (
          <div class="flex items-baseline gap-4">
            <span class={rowLabel}>--weight-{w}</span>
            <Text size="lg" weight={w}>
              {specimen}
            </Text>
          </div>
        ))
      }
    </div>
  </div>

  <div class={groupClass}>
    <p class={labelClass}>Line height (leading)</p>
    <div class="grid gap-8 sm:grid-cols-2">
      {
        leadings.map((l) => (
          <div>
            <p class={labelClass}>--leading-{l}</p>
            <Text leading={l} measure>
              {paragraph}
            </Text>
          </div>
        ))
      }
    </div>
  </div>

  <div class={groupClass}>
    <p class={labelClass}>Letter spacing (tracking / kerning)</p>
    <div class="space-y-3">
      {
        trackings.map((t) => (
          <div class="flex items-baseline gap-4">
            <span class={rowLabel}>--tracking-{t}</span>
            <Heading level={2} size="md" tracking={t} class="truncate">
              {specimen}
            </Heading>
          </div>
        ))
      }
    </div>
  </div>

  <div class={groupClass}>
    <p class={labelClass}>Color tokens</p>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
      {
        colors.map((c) => (
          <div>
            <div class={`h-20 w-full rounded-md border border-border ${c.box}`} />
            <Text size="sm" weight="medium" class="mt-2">
              {c.name}
            </Text>
            <Text size="xs" tone="muted" class="font-mono">
              {c.token}
            </Text>
          </div>
        ))
      }
    </div>
  </div>
</Section>
