---
import Section from "@ui/Section.astro";
import Container from "@ui/Container.astro";
import Heading from "@ui/Heading.astro";
import ImageBlock from "@ui/ImageBlock.astro";
import { home } from "@content/home";
const { artists } = home;
import H3 from "@ui/Heading.astro";

// Single source of truth for the section. `--banner-h` (set on the pin wrapper
// below) drives the banner height, the offset that drops the names window to
// the banner's base, and that window's height. Change just this one value.
const BANNER_H = "80vh";
---
<Section id="artists" width="full" tone="surface">

    <div
      class="artists__pin md:grid md:grid-cols-2 md:items-start md:gap-x-8"
      style={`--banner-h: ${BANNER_H}`}
    >
      <div class="md:self-start">

        <div class="artists__banner pb-8 pt-16 bg-surface w-full overflow-hidden rounded-lg md:w-[calc(200%_+_2rem)]">
          <ImageBlock
            src=""
            alt=""
            class="artists__banner-img h-full w-full rounded-lg object-cover"
          />
        </div>
        <H3>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque
          nulla tellus, tristique id pretium a, dictum et lorem.
        </H3>
      </div>

      <div class="artists__viewport">
        <ul class="artists__track flex flex-col">
          {
            artists.items.map((artist) => (
              <li class="group">
                <a href={artist.href || "/contact"} class="block">
                  <Heading level={2} size="2xl" class="artists__name">
                    {artist.name}
                  </Heading>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
</Section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let mm: ReturnType<typeof gsap.matchMedia> | undefined;

  function build() {
    mm?.revert();

    const section = document.querySelector<HTMLElement>("#artists");
    if (!section) return;

    mm = gsap.matchMedia();

    // Desktop: pin the banner + heading once the banner reaches the top, then
    // scrub the names through their own clipped window. The page is frozen
    // while pinned, so names scroll inside the masked layer instead of sliding
    // up under the banner.
    mm.add(
      "(min-width: 768px) and (prefers-reduced-motion: no-preference)",
      () => {
        const pin = section.querySelector<HTMLElement>(".artists__pin");
        const viewport = section.querySelector<HTMLElement>(".artists__viewport");
        const track = section.querySelector<HTMLElement>(".artists__track");
        if (!pin || !viewport || !track) return;

        viewport.classList.add("is-clipped");

        const distance = () =>
          Math.max(0, track.scrollHeight - viewport.clientHeight);

        // Ramp each edge's fade in/out over the first/last slice of the scroll
        // so the very start and end of the list read as crisp text.
        const MAX_FADE = 12; // matches the mask gradient stop (%)
        const RAMP = 0.06; // fraction of the scroll the fade ramps over
        const setFades = (progress: number) => {
          const top = Math.min(1, progress / RAMP) * MAX_FADE;
          const bottom = Math.min(1, (1 - progress) / RAMP) * MAX_FADE;
          viewport.style.setProperty("--fade-top", `${top}%`);
          viewport.style.setProperty("--fade-bottom", `${bottom}%`);
        };

        gsap.to(track, {
          y: () => -distance(),
          ease: "none",
          scrollTrigger: {
            trigger: pin,
            start: "top top+=2rem",
            end: () => "+=" + distance(),
            pin: true,
            // Lenis (SmoothScroll.astro) smooths the scroll position itself, so
            // the pin glides without anticipatePin; a light scrub keeps the
            // names following that eased scroll closely.
            scrub: 0.5,
            invalidateOnRefresh: true,
            onUpdate: (self) => setFades(self.progress),
          },
        });

        return () => {
          viewport.classList.remove("is-clipped");
          viewport.style.removeProperty("--fade-top");
          viewport.style.removeProperty("--fade-bottom");
          gsap.set(track, { clearProps: "transform" });
        };
      },
    );
  }

  build();
  document.addEventListener("astro:page-load", build);
</script>

<style>
  /* Clipped scroll window for the artist names — added by GSAP only when the
     pinned, animated layout is active (desktop + motion allowed). The mask
     fades names in/out at the edges; overflow:hidden hides the scrollbar. */
  /* Banner height and the list's drop both derive from --banner-h (set on
     .artists__pin), so they move together when you change that one value. */
  .artists__banner {
    height: var(--banner-h);
  }

  @media (min-width: 768px) {
    .artists__viewport {
      margin-top: var(--banner-h);
    }
  }

  .artists__viewport.is-clipped {
    /* Fade sizes are driven by scroll progress in JS: the top fade is 0 at the
       start of the list and the bottom fade is 0 at the end, so the first and
       last names stay crisp instead of washing out. */
    --fade-top: 0%;
    --fade-bottom: 12%;
    /* Fill the space left under the pinned banner: viewport height minus the
       banner, the 2rem pin offset, and a little breathing room. */
    height: calc(100vh - var(--banner-h) - 4rem);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 var(--fade-top),
      #000 calc(100% - var(--fade-bottom)),
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 var(--fade-top),
      #000 calc(100% - var(--fade-bottom)),
      transparent 100%
    );
  }
</style>
