---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@ui/Container.astro";
import Heading from "@ui/Heading.astro";
import Section from "@ui/Section.astro";
import ImageBlock from "@ui/ImageBlock.astro";
import DitherImage from "@ui/DitherImage.astro";
import ArrowLink from "@ui/ArrowLink.astro";
import { company } from "@content/company";

const { about } = company;
---

<BaseLayout seo={{ title: "About", description: about.lead }}>
  <section class="h-svh w-full overflow-hidden">
    <ImageBlock
      src={about.heroImage}
      alt={about.heroImageAlt}
      loading="eager"
      sizes="100vw"
      class="h-full w-full object-cover"
    />
  </section>

<Section width="full" tone="surface" class="relative" contained={false}>
    <Container
      width="full"
      class="grid grid-cols-1 items-start gap-10 md:grid-cols-3 md:gap-12"
    >
      <Heading level={1} size="2xl" class="whitespace-pre-line">{about.title}</Heading>

      <DitherImage
        src={about.image}
        alt={about.imageAlt}
        class="aspect-square w-full object-cover h-[50vh]"
      />

      <div class="flex flex-col items-start gap-6">
        {
          about.body.map((paragraph) => (
            <Heading
              level={2}
              tone="muted"
              class="max-w-prose"
            >
              {paragraph}
            </Heading>
          ))
        }
        <ArrowLink href={about.cta.href} label={about.cta.label} class="mt-8 border-2 border-text"/>
      </div>
    </Container>
  </Section>
</BaseLayout>
