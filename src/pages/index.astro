---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";
import Heading from "@ui/Heading.astro";
import Text from "@ui/Text.astro";
import Button from "@ui/Button.astro";
import ImageBlock from "@ui/ImageBlock.astro";
import CTA from "@sections/CTA.astro";
import Services from "@sections/Services.astro";
import { home } from "@content/home";
import { site } from "@content/site";
// Single local placeholder asset reused across the work tiles.
import placeholder from "@assets/images/test-large.jpg";
import H3 from "@ui/Heading.astro";
const { hero, manifesto, work, stats, cta } = home;
---

<BaseLayout seo={{ title: "Home", titleAbsolute: true }}>
  {/* ── Hero ─────────────────────────────────────────────────────────────
       Minimalist: the wordmark carries it. Height by 3 levels:
       mobile 88svh · sm 90svh · lg+ 100svh (always full).             */}
  <section
    data-theme="dark"
    class="sticky top-8 z-0 h-[88svh] overflow-hidden bg-bg text-text sm:h-[90svh] lg:h-svh"
  >
  <div class="hero-parallax absolute inset-0 will-change-transform">
    {/* placeholder reel image + scrim for legibility */}
    <ImageBlock
      src={placeholder}
      alt=""
      loading="eager"
      sizes="100vw"
      class="hero-img absolute inset-0 h-full w-full will-change-transform"
    />



    <div
      class="absolute inset-0 bg-[linear-gradient(to_top,rgba(0,0,0,0.85),rgba(0,0,0,0.4)_45%,rgba(0,0,0,0.2))]"
      aria-hidden="true"
    >
    </div>


    </div>


  </section>

  {/* Everything below scrolls up over the pinned hero. */}
  <div class="relative z-10">
     <div class="text-white flex justify-center w-full absolute flex-col -top-[88vh] text-center gap-[60vh]">
          <div>
        Lorem ipsum dolor sit amet,<br/>consectetur adipiscing elit. <br/>Pellentesque nulla tellus,<br/> tristique id pretium a, <br/>dictum et lorem.
      </div>
    <H3>Matr labs</H3>
    </div>
  <Section width="full" tone="surface">
    <Container width="full" class="relative flex flex-1 flex-col justify-end gap-12">
      {/* wordmark */}
      <div class="hero-rise flex flex-col gap-6">
        <Heading level={1} size="hero" tracking="tighter">
         Neque porro quisquam est qui dolorem ipsum quia dolor sit amet.
        </Heading>
        <H3>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque nulla tellus, tristique id pretium a, dictum et lorem. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Fusce eu nunc justo. Vestibulum feugiat sollicitudin euismod. Duis et augue bibendum, commodo dui vitae, varius felis. Proin finibus, purus pretium pretium vulputate, mi eros molestie purus, nec laoreet lacus magna sed sem. Integer vulputate mauris quis arcu lobortis pretium.</H3>
      </div>
    </Container>


  </Section>
  {/* ── Selected work ──────────────────────────────────────────────────── */}
  <Section id="work" width="default">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
      <div>
        <Text size="sm" tone="muted" class="font-mono uppercase tracking-wide">
          {work.label}
        </Text>
        <Heading level={2} size="xl" class="mt-3">{work.title}</Heading>
      </div>
    </div>

    <ul class="grid grid-cols-1 gap-x-6 gap-y-12 sm:grid-cols-2">
      {
        work.items.map((item) => (
          <li class="work-card group">
            <a href="/contact" class="block">
              <div class="overflow-hidden rounded-lg bg-surface">
                <ImageBlock
                  src={placeholder}
                  alt={`${item.title} — placeholder image`}
                  sizes="(min-width: 640px) 50vw, 100vw"
                  class="aspect-[4/3] h-full transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                />
              </div>
              <div class="mt-4 flex items-baseline justify-between gap-4">
                <Heading level={3} size="md">{item.title}</Heading>
                <Text size="sm" tone="muted" class="font-mono">
                  {item.year}
                </Text>
              </div>
              <Text size="sm" tone="muted" class="mt-1 font-mono uppercase tracking-wide">
                {item.category}
              </Text>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* ── Services (sticky-stacking panels) ──────────────────────────────── */}
  <Services />

  </div>
</BaseLayout>

<style>
  /* Base zoom gives the parallax drift room to move without exposing edges. */
  .hero-img {
    transform: scale(1.25);
    transform-origin: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-img {
      transform: none !important;
    }
  }

  .hero-rise {
    animation: hero-rise 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scroll-dot {
    animation: scroll-pulse 1.8s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(0.7);
    }
  }
</style>

<script>
  // Light parallax: the pinned hero image drifts up at a fraction of scroll
  // speed, so it doesn't fully follow the page while the sections below cover
  // it. Scroll position is required, so a rAF-throttled handler is justified.
  const FACTOR = 0.1; // image moves at 10% of scroll — kept under the 1.25 zoom
  let ticking = false;

  const prefersReduce = () =>
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function render() {
    ticking = false;
    // Translate only — the wrapper moves image + text together. The image's
    // own scale(1.25) lives in CSS (.hero-img) so the text isn't scaled.
    const layer = document.querySelector<HTMLElement>(".hero-parallax");
    if (!layer) return;
    if (prefersReduce()) {
      layer.style.transform = "";
      return;
    }
    const shift = Math.max(0, window.scrollY) * FACTOR;
    layer.style.transform = `translate3d(0, ${-shift}px, 0)`;
  }

  function onScroll() {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(render);
    }
  }

  window.addEventListener("scroll", onScroll, { passive: true });
  // Re-sync on initial load and after every view-transition navigation.
  document.addEventListener("astro:page-load", render);
</script>
