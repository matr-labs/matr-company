---
import BaseLayout from "@layouts/BaseLayout.astro";
import Contact from "@sections/Contact.astro";
import { site } from "@content/site";
---

<BaseLayout seo={{ title: "Contact", description: `Get in touch with ${site.name}.` }}>
  <Contact
    title="Let's talk"
    intro={`Email us at ${site.email} or use the form below. We reply within two business days.`}
  />
</BaseLayout>
