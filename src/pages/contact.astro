---
import BaseLayout from "@layouts/BaseLayout.astro";
import Contact from "@sections/Contact.astro";
import { site } from "@content/site";
---

<BaseLayout seo={{ title: "Contact", description: `Get in touch with ${site.name}.` }}>
  <Contact
    title="Let's talk."
    intro={`Email us at ${site.email} or use the form.\nWe reply within two business days.`}
  />

  <div class="pointer-events-none fixed inset-0 z-[60] overflow-hidden bg-white mix-blend-difference">
    <div
      data-invert-mask
      class="absolute inset-0 bg-black will-change-transform"
    ></div>
  </div>
</BaseLayout>

<script>
  // SMALL = resting scale after the intro shrink (1 = fills everything).
  // FILL_DISTANCE = px of scroll needed to fill back to full (smaller = more
  // sensitive — fills with the slightest scroll).
  const SMALL = 0.90;
  const FILL_DISTANCE = 200;
  const MAX = 1;
  const clamp = (n: number) => Math.min(Math.max(n, 0), 1);
  const scaleFor = (p: number) => SMALL + (MAX - SMALL) * clamp(p);
  const progress = () => window.scrollY / FILL_DISTANCE;
  const transformFor = (p: number) => `scale(${scaleFor(p)})`;

  let introDone = false;

  function apply() {
    const mask = document.querySelector<HTMLElement>("[data-invert-mask]");
    if (mask && introDone) mask.style.transform = transformFor(progress());
  }

  function setup() {
    const mask = document.querySelector<HTMLElement>("[data-invert-mask]");
    introDone = false;
    if (!mask) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      introDone = true;
      mask.style.transform = transformFor(progress());
      return;
    }

    mask.style.transition = "none";
    mask.style.transform = "scale(1)";
    requestAnimationFrame(() => {
      mask.style.transition = "transform 1s cubic-bezier(0.16, 1, 0.3, 1)";
      mask.style.transform = transformFor(progress());
    });
    window.setTimeout(() => {
      mask.style.transition = "";
      introDone = true;
    }, 1000);
  }

  let ticking = false;
  window.addEventListener(
    "scroll",
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        apply();
        ticking = false;
      });
    },
    { passive: true },
  );

  setup();
  document.addEventListener("astro:page-load", setup);
</script>
