---
import ImageBlock from "@ui/ImageBlock.astro";
import placeholder from "@assets/images/test-large.jpg";
import BaseLayout from "@layouts/BaseLayout.astro";
---
<BaseLayout seo={{ title: "Home", titleAbsolute: true }}>
  <div class="stage">
    <div class="counter">
      <p>0</p>
    </div>

    <section class="hero">
      <div class="hero-img">
        <ImageBlock
          src={placeholder}
          alt=""
          loading="eager"
          sizes="100vw"
          class="h-full w-full object-cover"
        />
      </div>

      {/* The black box: a random-stipple dither that wipes up (grow then rise). */}
      <div class="overlay"><canvas data-overlay-dither></canvas></div>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .stage {
    position: fixed;
    inset: 0;
    z-index: 20;
    overflow: hidden;
    background-color: #ffffff; /* the white field the dither reads against */
  }

  .counter {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 20px;
    text-align: center;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
    z-index: 3; /* above the black box */
    mix-blend-mode: difference; /* readable on white field and black box alike */
    color: #ffffff;
  }

  .counter p {
    position: relative;
    display: block;
    transform: translateY(20px);
  }

  .hero {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.7);
    width: 100vw;
    height: 100vh;
    will-change: transform;
    z-index: 1;
    background-color: #ffffff;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .overlay canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
  }
</style>

<script>
  import gsap from "gsap";
  import { CustomEase } from "gsap/CustomEase";

  // ── Black box: random-stipple dither (B&W). The dithered front sweeps up —
  // black grows in bottom→top (dithered TOP edge), fills solid, then clears
  // bottom→top (dithered BOTTOM edge) revealing the hero. Static noise field so
  // the stipple doesn't flicker; only the coverage front moves.
  const PX = 2; // dither cell size (px) — smaller = finer grain
  const SOFT = 0.35; // height (fraction of box) of the soft dithered front

  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let cols = 0;
  let rows = 0;
  let img: ImageData | null = null;
  let thr = new Float32Array(0);
  let covRow = new Float32Array(0);
  const state = { grow: 0, rise: 0 };

  function size() {
    if (!canvas || !ctx) return false;
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    if (!w || !h) return false;
    cols = Math.max(1, Math.ceil(w / PX));
    rows = Math.max(1, Math.ceil(h / PX));
    canvas.width = cols;
    canvas.height = rows;
    img = ctx.createImageData(cols, rows);
    covRow = new Float32Array(rows);
    thr = new Float32Array(cols * rows);
    for (let i = 0; i < thr.length; i++) thr[i] = Math.random();
    return true;
  }

  function renderDither() {
    if ((!img && !size()) || !img || !ctx) return;
    const data = img.data;
    const denom = rows > 1 ? rows - 1 : 1;
    // Black occupies a vertical band; the moving edge is the soft dithered front.
    const bandTop = (1 + SOFT) * (1 - state.grow); // grow: top edge sweeps up
    const bandBottom = 1 - state.rise * (1 + SOFT); // rise: bottom edge sweeps up
    for (let y = 0; y < rows; y++) {
      const yN = y / denom;
      const covTop = Math.min(1, Math.max(0, (yN - (bandTop - SOFT)) / SOFT));
      const covBottom = Math.min(1, Math.max(0, (bandBottom + SOFT - yN) / SOFT));
      covRow[y] = Math.min(covTop, covBottom); // coverage = black probability
    }
    for (let y = 0; y < rows; y++) {
      const cov = covRow[y];
      for (let x = 0; x < cols; x++) {
        const idx = y * cols + x;
        const i = idx * 4;
        data[i] = 0;
        data[i + 1] = 0;
        data[i + 2] = 0;
        data[i + 3] = cov > thr[idx] ? 255 : 0; // black dot or transparent
      }
    }
    ctx.putImageData(img, 0, 0);
  }

  document.addEventListener("DOMContentLoaded", () => {
    gsap.registerPlugin(CustomEase);
    CustomEase.create(
      "hop",
      "M0,0 C0.29,0 0.348,0.05 0.422,0.134 0.494,0.217 0.484,0.355 0.5,0.5 0.518,0.662 0.515,0.793 0.596,0.876 0.701,0.983 0.72,0.987 1,1 ",
    );

    canvas = document.querySelector<HTMLCanvasElement>("[data-overlay-dither]");
    ctx = canvas ? canvas.getContext("2d") : null;
    size();
    renderDither();
    window.addEventListener("resize", () => {
      if (size()) renderDither();
    });

    const counter = document.querySelector<HTMLElement>(".counter p");
    const heroImg = document.querySelector<HTMLElement>(".hero-img");
    const count = { v: 0 };

    gsap.set(heroImg, { autoAlpha: 0 }); // hero hidden until the box clears it

    const tl = gsap.timeline();
    // Counter rises into its window.
    tl.fromTo(counter, { y: 20 }, { y: 0, duration: 1, ease: "power3.out" }, 1);
    // Counter counts up on the white field (the box stays empty until it's done).
    tl.to(
      count,
      {
        v: 100,
        duration: 2,
        ease: "none",
        onUpdate: () => {
          if (counter) counter.textContent = String(Math.round(count.v));
        },
      },
      ">",
    );
    // Counter rises out — the reveal begins AFTER the count, not during it.
    tl.to(counter, { y: -20, duration: 1, ease: "power3.inOut" }, ">");
    // Black box dithers in from the bottom (grow), only now that counting is done.
    tl.to(state, { grow: 1, duration: 1.4, ease: "none", onUpdate: renderDither }, "<");
    // Reveal: bring the hero in behind the full box, then the box clears up.
    tl.set(heroImg, { autoAlpha: 1 });
    tl.to(state, { rise: 1, duration: 2, ease: "hop", onUpdate: renderDither }, ">");
    tl.to(
      ".hero",
      { transform: "translate(-50%, -50%) scale(1)", duration: 2.25, ease: "power3.inOut" },
      "<",
    );
  });
</script>
