# Copy to .env and fill in. Astro exposes server-only vars to endpoints/SSR.
# Anything prefixed with PUBLIC_ is also exposed to client code.

# Contact form delivery (used by src/lib/email.ts)
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=no-reply@example.com

# Email provider API key (e.g. Resend, Postmark, SendGrid)
EMAIL_API_KEY=
